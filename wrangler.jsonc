{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "danjacky-collaborative-accounting",
  "compatibility_date": "2024-04-01",
  "pages_build_output_dir": ".",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "monthly_expenses",
      "database_id": "82898e5c-694c-594f-82d1-cb27d406f7bc"
    }
  ],
  "vars": {
    "TELEGRAM_BOT_TOKEN": "REPLACE_WITH_YOUR_TOKEN",
    "TELEGRAM_CHAT_ID": "REPLACE_WITH_YOUR_CHAT_ID"
  }
}
